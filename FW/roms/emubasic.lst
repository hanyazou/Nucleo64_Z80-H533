              	;	EMUBASIC based on GRANT's BASIC
              	;	TARGET: EMUZ80
              	;	ASSEMBLER: ARCPIT XZ80.EXE
              	;
              	;	START UP ROUTINE
              	;	VERSION 1.0, 2022/02/15
              	;	WRITTEN by TETSUYA SUZUKI
              	;
              		.include "io_asm.inc"
              	;	Common definitions for Z80-Simulator
              	;
              	;	Copyright (C) 1988-2007 by Udo Munk
              	;
              	;
              	;	SuperMEZ80 I/O ports
              	;
0000:         	CONSTA		EQU	0		;console status port
0001:         	CONDAT		EQU	1		;console data port
0002:         	PRTSTA		EQU	2		;printer status port
0003:         	PRTDAT		EQU	3		;printer data port
0005:         	AUXDAT		EQU	5		;auxiliary data port
0008:         	FDCDAT		EQU	8		;fdc-port: # of drive
000A:         	FDCD		EQU	10		;fdc-port: # of drive
000B:         	FDCT		EQU	11		;fdc-port: # of track
000C:         	FDCS		EQU	12		;fdc-port: # of sector
000D:         	FDCOP		EQU	13		;fdc-port: command
0000:         			D_DMA_READ	EQU	0
0001:         			D_DMA_WRITE	EQU	1
0002:         			D_READ		EQU	2
0003:         			D_WRITE		EQU	3
000E:         	FDCST		EQU	14		;fdc-port: status
0000:         			D_SUCCESS	EQU	0
0001:         			D_ERROR		EQU	1
000F:         	DMAL		EQU	15		;dma-port: dma address low
0010:         	DMAH		EQU	16		;dma-port: dma address high
0014:         	MMU_INIT	EQU	20		;14h MMU initialisation
0015:         	MMU_BANK_SEL	EQU	21		;15h MMU bank select
0016:         	MMU_SEG_SIZE	EQU	22		;16h MMU select segment size (in pages a 256 bytes)
0017:         	MMU_WR_PROT	EQU	23		;17h MMU write protect/unprotect common memory segment
              	;
              	;	MEMORY ASIGN
0000:         	ROMTOP	EQU	0000H
8000:         	RAMTOP	EQU	8000H
1000:         	RAMSIZ	EQU	1000H
80ED:         	TSTACK	EQU	80EDH
              	;
              	;	UART REGISTER ADDRESS
0001:         	UARTDR	EQU	CONDAT	; UART DATA REGISTOR
0000:         	UARTCR	EQU	CONSTA	; UART CONTROL REGISTOR
              	;
              	;	RESET (RST 00H)
0000:         		ORG	ROMTOP
0000: F3      		DI
0001: 31ED80  		LD	SP,TSTACK
0004: C33400  		JP	SINIT
              	;
              	;	PUT 1CHAR (RST 08H)
              		ORG	ROMTOP+08H
0008: C33100  		JP	TXA
              	;
              	;	GET 1CHAR (RST 10H)
              		ORG	ROMTOP+10H
0010: C31B00  		JP	RXA
              	;
              	;	KBHIT (RST 18H)
              		ORG	ROMTOP+18H
0018: C32C00  		JP	KBHIT
              	;
              	;	UART -> A
001B: DB00    	RXA:	IN	A,(UARTCR)
001D: CB47    		BIT	0,A
001F: 28FA    		JR	Z,RXA
0021: DB01    		IN	A,(UARTDR)
0023: FE61    		CP	'a'
0025: D8      		RET	C
0026: FE7B    		CP	'z'+1
0028: D0      		RET	NC
0029: E6DF    		AND	0DFH
002B: C9      		RET
              	;
              	;	CHECK RECEIVE STATUS
002C: DB00    	KBHIT:	IN	A,(UARTCR)
002E: CB47    		BIT	0,A
0030: C9      		RET
              	;
              	;	A -> UART
              	;	NOTE: TX is always ready on Nucleo64 Z80
0031: D301    	TXA:	OUT	(UARTDR),A
0033: C9      		RET
              	;
              	;
              	;	SYSTEM INITIALIZE
0034:         	SINIT:
0034: C33700  		JP	COLD
